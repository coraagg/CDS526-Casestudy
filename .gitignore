with open('.gitignore', 'w') as f:
    f.write("""
# Ignore all pickle files (results data)
*.pkl

# Ignore the entire results_fixed directory (if you don't want to commit any of its contents)
results_fixed/

# Optionally ignore the original results directory if you only want to commit images
# But you want to commit images, so we will NOT ignore the whole results directory.
# Instead, we will selectively add images.
# So we DO NOT add "results/" here.

# Ignore Python cache and other temp files
__pycache__/
*.pyc
.ipynb_checkpoints/
""")
